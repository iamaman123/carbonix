# Copy to .env — never commit .env
#
# Vercel: Project → Settings → Environment Variables (Production + Preview).
#   Required for Google login: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#   If these are missing, the API boots but sign-in shows "google_not_configured".

MONGODB_URI=
PORT=8000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

JWT_SECRET=
JWT_EXPIRY=7d

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID
# GOOGLE_CALLBACK_URL = the URL where THIS server receives GET /api/auth/google/callback
#   Local:  http://localhost:8000/api/auth/google/callback
#   Vercel: https://YOUR-API-PROJECT.vercel.app/api/auth/google/callback  (same host as your API, with https)
# Add the SAME string under "Authorised redirect URIs" in Google Console (wait a few minutes after save).
# CLIENT_URL = your Vite / frontend URL (e.g. https://carbonix-hazel.vercel.app) for post-login redirects.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

GEMINI_API_KEY=

# Razorpay (Dashboard → API Keys). Test: rzp_test_… + matching secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

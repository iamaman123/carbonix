# Copy to .env — never commit .env

MONGODB_URI=
PORT=8000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

JWT_SECRET=
JWT_EXPIRY=7d

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID
# 1) Authorised redirect URIs — ADD this exact line (backend callback, not Vite):
#    http://localhost:8000/api/auth/google/callback
# 2) Authorised JavaScript origins — include:
#    http://localhost:8000
#    http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

GEMINI_API_KEY=

# Razorpay (Dashboard → API Keys). Test: rzp_test_… + matching secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

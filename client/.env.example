# Full API base URL including https:// and /api suffix. Must match where your Express API is deployed.
# Example: https://carbonix-me-1.vercel.app/api  or  https://carbonix-hazel.vercel.app/api  if API is on that project.
VITE_API_URL=https://carbonix-me-1.vercel.app/api

# Optional: only if you want to override the key returned by the API (not required for checkout).
# VITE_RAZORPAY_KEY_ID=rzp_test_...
